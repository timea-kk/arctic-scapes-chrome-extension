{
  "name": "arctic-scapes",
  "version": "1.0.0",
  "description": "Arctic Scapes - A Chrome new tab extension with arctic landscape photography",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "npm run build && http-server . -p 3000 --cors -c-1 -o newtab.html",
    "download-fallbacks": "node scripts/download-fallbacks.js",
    "fill-missing-locations": "node scripts/fill-missing-locations.js",
    "replenish-photos": "node scripts/replenish-photos.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "replace-morning-flagged": "node scripts/replace-morning-flagged.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/chrome": "^0.1.37",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "http-server": "^14.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
